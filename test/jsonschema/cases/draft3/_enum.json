[
  {
    "description": "enums in properties",
    "schema": {
      "type": "object",
      "properties": {
        "foo": {
          "enum": [
            "foo"
          ]
        },
        "bar": {
          "enum": [
            "bar"
          ],
          "required": true
        }
      }
    },
    "tests": [
      {
        "description": "missing required property is invalid",
        "data": {
          "foo": "foo"
        },
        "valid": false
      },
      {
        "description": "missing all properties is invalid",
        "data": {},
        "valid": false
      }
    ]
  }
]